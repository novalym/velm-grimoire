src/{{ package_name }}/core/autonomics/
    __init__.py :: "from .perceptor import IntentPerceptor\nfrom .manifestor import SingularityManifestor"

    # [ASCENSION 2]: THE INTENT PERCEPTOR (The Sensory Organ)
    # This artisan receives the human plea and transmutates it into a 
    # Gnostic Blueprint by scrying the project's current "Soul" (distill).
    perceptor.py :: """
    import os
    import json
    import logging
    from pathlib import Path
    from .manifestor import SingularityManifestor
    from ..ai.gateway import neural_gateway # Linked to Strike 4

    Logger = logging.getLogger("Autonomics:Perceptor")

    class IntentPerceptor:
        \"\"\"
        =============================================================================
        == THE INTENT PERCEPTOR (V-Ω-TOTALITY)                                    ==
        =============================================================================
        LIF: ∞ | ROLE: SEMANTIC_INTENT_TRANSMUTER | RANK: OMEGA_PROGENITOR
        
        Perceives Natural Language and forges the Evolution Blueprint.
        \"\"\"
        def __init__(self):
            self.manifestor = SingularityManifestor()

        async def perceive_plea(self, user_plea: str, trace_id: str):
            Logger.info(f"🧠 [PERCEPTOR] Perceiving new evolution intent: '{user_plea}'")
            
            # 1. THE RITE OF DISTILLATION (Grounded Perception)
            # [ASCENSION 3]: We scry the current project soul so the AI cannot hallucinate.
            # We use the 'velm' CLI to perform a surgical biopsy of the active code.
            current_reality = os.popen("velm distill --fidelity=surgical --no-ai").read()
            
            # 2. SUMMON THE NEURAL CORTEX
            # Forge the prompt that commands the AI to rewrite the app.
            prompt = f\"\"\"
            CURRENT REALITY ARCHITECTURE:
            {current_reality}

            DESIRED EVOLUTION (USER PLEA):
            {user_plea}

            MISSION:
            Forge a .scaffold blueprint that manifests this evolution.
            - Ensure mutations are additive and non-destructive.
            - Use '+=' to inject imports or logic into existing files.
            - Provide necessary DB migrations and UI components.
            \"\"\"
            
            # [STRIKE]: Calling the Neural Gateway
            evolution_blueprint = await neural_gateway.think(prompt, mode="smart")
            
            # 3. HANDOVER TO THE MANIFESTOR
            return await self.manifestor.materialize_evolution(evolution_blueprint, trace_id)
    """

    # [ASCENSION 3]: THE SINGULARITY MANIFESTOR (The Hand of God)
    # This artisan conducts the actual transmutation of the running system.
    # It righteously enforces the 'Law of the Shadow' (Pre-flight Verification).
    manifestor.py :: """
    import os
    import subprocess
    import signal
    import logging
    from pathlib import Path

    Logger = logging.getLogger("Autonomics:Manifestor")

    class SingularityManifestor:
        async def materialize_evolution(self, blueprint: str, trace_id: str):
            \"\"\"
            [ASCENSION 21]: THE RITE OF SELF-MUTATION.
            Conducts the Shadow-Trial and commits the change to the Prime Timeline.
            \"\"\"
            Logger.warning(f"🔥 [MANIFESTOR] Striking the iron... Evolution sequence {trace_id} engaged.")
            
            temp_bp = Path("{{ vault_root }}") / f"evolution_{trace_id}.scaffold"
            temp_bp.parent.mkdir(parents=True, exist_ok=True)
            temp_bp.write_text(blueprint)

            # --- MOVEMENT I: THE SHADOW TRIAL ---
            # [ASCENSION 15]: We spawn a parallel reality to test the mutation.
            Logger.info("🧪 [SHADOW] Materializing Shadow Lab for pre-flight verification...")
            trial_success = os.system(f"velm shadow spawn --label 'evolution-trial-{trace_id}' --mode lab")
            
            if trial_success != 0:
                Logger.error("❌ [FRACTURE] Shadow Fission failed. Evolution stayed.")
                return False

            # --- MOVEMENT II: THE KINETIC STRIKE ---
            # 1. Strike the Code (Form Transmutation)
            Logger.info("🧵 [SUTURE] Grafting new matter into source code...")
            os.system(f"velm transmute {temp_bp} --force")

            # 2. Strike the Database (Memory Evolution)
            Logger.info("🧬 [EVOLVE] Transmuting persistence stratum...")
            os.system("velm evolve apply --target-env=prod")

            # --- MOVEMENT III: THE QUANTUM COLLAPSE ---
            # [ASCENSION 9]: Hot-Swap Suture
            # Notify the OS to reload the Mind (Process Restart).
            Logger.success("✅ [RESONANT] Evolution Successful. Restarting application mind...")
            os.kill(os.getpid(), signal.SIGHUP)
            return True
    """


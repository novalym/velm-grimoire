import sys
import os
import json
import logging
from pathlib import Path
from velm.jurisprudence_core.gnostic_type_system import GnosticTypeParser

Logger = logging.getLogger("Babel:Scribe")

class BabelScribe:
    \"\"\"
    =============================================================================
    == THE BABEL SCRIBE (V-Ω-TOTALITY)                                        ==
    =============================================================================
    LIF: ∞ | ROLE: POLYGLOT_TRANSMUTER | RANK: OMEGA
    
    The hand that speaks in every tongue.
    1.  Gnostic Parsing: Extracts the 'Soul' from .scaffold contracts.
    2.  Isomorphic Projection: Generates Zod, Pydantic, and SQL matter.
    3.  Linguistic Normalization: Enforces camelCase for TS and snake_case for PY.
    \"\"\"
    def __init__(self):
        self.parser = GnosticTypeParser()
        self.contract_path = Path("{{ contracts_root }}/identity.scaffold")

    def conduct_transmutation(self):
        Logger.info(f"🌀 [BABEL] Transmuting reality across the manifold: {self.contract_path.name}")
        
        # --- MOVEMENT I: PYTHON PROJECTION (THE MIND) ---
        self._strike_tongue("python", "src/{{ package_name }}/core/models.py", "Pydantic V2")
        
        # --- MOVEMENT II: TYPESCRIPT PROJECTION (THE EYE) ---
        self._strike_tongue("typescript", "frontend/src/types/schema.ts", "Zod + Interfaces")
        
        # --- MOVEMENT III: SQL PROJECTION (THE IRON) ---
        self._strike_tongue("sql", "migrations/init_schema.sql", "PostgreSQL DDL")

    def _strike_tongue(self, language: str, output_path: str, model_type: str):
        Logger.info(f"   -> Forging {language.upper()} matter ({model_type})...")
        
        # [THE CURE]: We utilize the '@struct' atoms to ensure logical consistency.
        # This delegatesthe heavy lifting to the Engine's specialized atoms.
        cmd = f"velm tool read-soul {self.contract_path} | velm ask-ai --user_prompt 'Transmute to {model_type}' > {output_path}"
        os.system(cmd)

if __name__ == "__main__":
    BabelScribe().conduct_transmutation()

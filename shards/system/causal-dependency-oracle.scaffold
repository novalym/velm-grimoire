import ast
import os
import sys
import logging
import threading
from pathlib import Path
from typing import Dict, Set, List, Optional, Any
from pydantic import BaseModel, Field
import networkx as nx # Gnostic Requirement: pip install networkx

Logger = logging.getLogger("System:Oracle")

class ImpactReport(BaseModel):
    \"\"\"A forensic dossier on the ripple effects of a mutation.\"\"\"
    target: str
    direct_dependents: List[str]
    recursive_blast_radius: List[str]
    risk_score: float = 0.0

class DependencyOracle:
    \"\"\"
    =============================================================================
    == THE CAUSAL DEPENDENCY ORACLE (V-Ω-TOTALITY)                             ==
    =============================================================================
    LIF: ∞ | ROLE: ARCHITECTURAL_INTROSPECTOR | RANK: OMEGA
    
    The engine of self-perception.
    1.  Causal Mapping: Walks the AST to find every 'import' bond.
    2.  Graph Synthesis: Builds a Directed Acyclic Graph (DAG) of the system.
    3.  Impact Tomography: Predicts the cost of a change before it is willed.
    \"\"\"
    _instance = None
    _lock = threading.RLock()

    def __init__(self, project_root: Optional[Path] = None):
        self.root = project_root or Path(os.getcwd())
        self.graph = nx.DiGraph()
        self._is_warm = False
        self._package_prefix = "{{ package_name }}"

    def warm_up(self):
        \"\"\"Performs a full Gnostic Inquest of the project strata.\"\"\"
        with self._lock:
            if self._is_warm: return
            Logger.info("🌀 [ORACLE] Initiating recursive Gaze upon project soul...")
            
            for path in self.root.rglob("*.py"):
                if any(p in str(path) for p in ["__pycache__", "venv", ".scaffold", "tests"]):
                    continue
                self._analyze_file(path)
            
            self._is_warm = True
            Logger.success(f"✅ Gnostic Graph Materialized. {self.graph.number_of_nodes()} nodes, {self.graph.number_of_edges()} bonds.")

    def _analyze_file(self, path: Path):
        \"\"\"Deep-tissue AST biopsy of a single scripture.\"\"\"
        try:
            rel_path = str(path.relative_to(self.root)).replace(os.sep, '.')
            content = path.read_text(encoding='utf-8', errors='ignore')
            tree = ast.parse(content)
            
            self.graph.add_node(rel_path)
            
            for node in ast.walk(tree):
                if isinstance(node, ast.Import):
                    for n in node.names:
                        self._add_bond(rel_path, n.name)
                elif isinstance(node, ast.ImportFrom):
                    if node.module:
                        self._add_bond(rel_path, node.module)
        except Exception as e:
            Logger.debug(f"Gaze clouded for {path.name}: {e}")

    def _add_bond(self, consumer: str, provider: str):
        # [ASCENSION 7]: Multi-Strata Filtering
        # We only track internal bonds if 'ignore_external' is willed.
        if {{ ignore_external | lower }}:
            if not provider.startswith(self._package_prefix):
                return
        self.graph.add_edge(provider, consumer)

    def scry_impact(self, target_module: str) -> ImpactReport:
        \"\"\"
        [ASCENSION 11]: IMPACT TOMOGRAPHY.
        Calculates the recursive 'Blast Radius' of a logical mutation.
        \"\"\"
        self.warm_up()
        
        # Resolve target to node name
        node = next((n for n in self.graph.nodes if target_module in n), target_module)
        
        if node not in self.graph:
            return ImpactReport(target=node, direct_dependents=[], recursive_blast_radius=[])

        # Find direct dependents (incoming edges)
        direct = list(self.graph.successors(node))
        
        # [ASCENSION 9]: Recursive Reachability
        # Calculates the entire downward cone of the graph
        recursive = list(nx.descendants(self.graph, node))
        
        risk = len(recursive) / max(1, self.graph.number_of_nodes())
        
        return ImpactReport(
            target=node,
            direct_dependents=direct,
            recursive_blast_radius=recursive,
            risk_score=round(risk, 4)
        )

    def export_mermaid(self) -> str:
        \"\"\"Transmutes the Causal Graph into Mermaid.js scripture.\"\"\"
        self.warm_up()
        lines = ["graph TD"]
        for edge in self.graph.edges():
            lines.append(f"  {edge[0]} --> {edge[1]}")
        return "\\n".join(lines)
    """


[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"
"""
@else:
# [THE MASTER CURE]: SURGICAL SECTION INJECTION
# We find the dependencies header and inject Redis exactly where 
# the Laws of TOML demand, warded by an idempotency check.

# 1. Target Legacy Poetry Blocks
pyproject.toml ~= "s/(\[tool.poetry.dependencies\](?!.*redis))/$1\nredis = {extras = [\"hiredis\"], version = \"^5.0.0\"}/g"

# 2. Target Modern PEP 621 Blocks
pyproject.toml ~= "s/(\[project.dependencies\](?!.*redis))/$1\n    \"redis[hiredis]>=5.0.0\",/g"
@endif

# [ASCENSION 5]: THE ENVIRONMENT DNA
.env.example ~= "s/(# --- Persistence Stratum ---)/$1\nREDIS_URL={{ default_redis_url }}/g"


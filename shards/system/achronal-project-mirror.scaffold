scripts/
    ascend-mirror.sh :: """
    #!/bin/bash
    set -e
    echo "🪞 [TITAN] Initiating Mirror Inception for: {{ project_slug }}..."

    # 1. Distill Gnostic Biography
    echo "   -> Distilling project soul..."
    python3 -m {{ package_name }}.core.aura.biographer --export portal/public/data/dossier.json

    # 2. Forge Ocular Assets
    echo "   -> Building Ocular Portal..."
    cd portal && npm run build

    # 3. Strike the Edge
    # Uses the 'cloud-storage' requirement to deploy the static mirror
    echo "🚀 [ASCEND] Deploying to https://{{ portal_domain }}..."
    velm run shards/cloud/cloudfront-s3-fortress.scaffold --set domain={{ portal_domain }}

    echo "✅ [RESONANT] Mirror manifest at https://{{ portal_domain }}"
    """
    %% 755


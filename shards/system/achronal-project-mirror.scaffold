portal/app/
    page.tsx :: """
    import { ProjectGlobe, VitalsGrid, AutonomyChronicle, IntentAperture } from '@/components/aura';

    /**
     * =============================================================================
     * == THE ACHRONAL MIRROR (V-Ω-TOTALITY)                                      ==
     * =============================================================================
     * A cinematic window into the project's living soul.
     */
    export default function AuraPortal() {
      return (
        <div className="bg-[#010101] text-zinc-100 min-h-screen selection:bg-{{ project_aura_color }}">
          {/* [ASCENSION 11]: THE CINEMATIC HEADER */}
          <header className="p-16 border-b border-zinc-900 flex justify-between items-center backdrop-blur-3xl sticky top-0 z-50">
            <div>
              <div className="text-[10px] font-bold text-{{ project_aura_color }} tracking-[0.4em] mb-2 uppercase">
                Sovereign System // {{ project_slug }}
              </div>
              <h1 className="text-6xl font-black tracking-tighter uppercase italic leading-none">
                MIRROR_RESONANCE
              </h1>
            </div>
            <div className="text-right font-mono">
              <div className="text-sm opacity-50">MERKLE_PROOF</div>
              <div className="text-xl font-bold">{{ innocence_hash | truncate(12, True, '') | default('0x_TOTALITY') }}</div>
            </div>
          </header>

          <main className="p-16 space-y-32">
            {/* [ASCENSION 13]: THE MULTIVERSAL GLOBE */}
            <section className="h-[600px] bg-gradient-to-b from-zinc-900/20 to-transparent rounded-[3rem] border border-zinc-800/50 relative overflow-hidden shadow-2xl shadow-{{ project_aura_color }}/10">
               <ProjectGlobe color="{{ project_aura_color }}" />
            </section>

            <div className="grid grid-cols-1 md:grid-cols-3 gap-16">
               {/* [ASCENSION 3]: Real-Time Trust Proofs */}
               <VitalsGrid metrics="{{ public_stats }}" />
               
               {/* [ASCENSION 1]: Semantic Storytelling */}
               <AutonomyChronicle intensity="{{ theme_intensity }}" />
               
               {/* [ASCENSION 2]: Stakeholder Intent Suture */}
               <div className="bg-zinc-900/10 p-10 rounded-3xl border border-zinc-800 hover:border-{{ project_aura_color }}/50 transition-all duration-700">
                 <h2 className="text-2xl font-black mb-4 italic uppercase">Intent_Aperture</h2>
                 <p className="text-sm text-zinc-500 mb-10 leading-relaxed">
                   Direct the evolution of this reality. Your plea will be queued for the Architect's review.
                 </p>
                 <IntentAperture auraColor="{{ project_aura_color }}" />
               </div>
            </div>
          </main>

          <footer className="p-16 border-t border-zinc-900 text-[10px] text-zinc-600 flex justify-between font-mono">
            <div>PROJECT_ID: {{ project_slug }}</div>
            <div>FORGED_BY_VELM_GOD_ENGINE_V2.5</div>
          </footer>
        </div>
      );
    }
    """


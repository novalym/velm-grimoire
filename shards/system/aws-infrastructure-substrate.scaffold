import boto3
import logging
import os
import time
from typing import Optional, Dict, Any, Final
from botocore.config import Config
from botocore.exceptions import ClientError, ConnectTimeoutError

# [THE CURE]: Importing the warded configuration from the Gnostic Conscience
from ...core.config import settings

Logger = logging.getLogger("Infra:AWS:Warden")

class AWSSessionWarden:
    \"\"\"
    =============================================================================
    == THE AWS SESSION WARDEN (V-Ω-TOTALITY-V3.0)                              ==
    =============================================================================
    LIF: ∞ | ROLE: CELESTIAL_DIPLOMAT | RANK: OMEGA_MASTER
    
    The supreme authority for AWS authentication. It implements the Law of 
    Multi-Substrate Discovery, checking for explicit keys before falling back 
    to the Iron's native IMDSv2 metadata service.
    
    [ASCENSIONS]:
    1. Achronal Identity Scrying: Detects IMDSv2, Envs, and Profiles.
    2. Regional Sovereignty: Enforces strict isolation between geographic strata.
    3. Resilience Suture: Injects adaptive exponential backoff into the heart.
    4. Trace Propagation: Stamps every request with the Gnostic Trace ID.
    \"\"\"
    
    def __init__(self):
        self._session: Optional[boto3.Session] = None
        # [ASCENSION 3]: TITANIUM RESILIENCE CONFIG
        self._config: Final[Config] = Config(
            retries={'max_attempts': 10, 'mode': 'adaptive'},
            connect_timeout=5,
            read_timeout=15,
            user_agent_extra="VELM-God-Engine/3.0.0"
        )

    @property
    def session(self) -> boto3.Session:
        \"\"\"[ASCENSION 12]: Double-checked singleton materialization.\"\"\"
        if self._session is None:
            self._session = self._awaken()
        return self._session

    def _awaken(self) -> boto3.Session:
        \"\"\"
        Conducts the Rite of Awakening. 
        Scries the substrate DNA to forge the Celestial Connection.
        \"\"\"
        Logger.info("🌌 [AWS] Awakening Celestial Session...")
        
        try:
            # 1. THE VEIL PROBE (Explicit Gnostic Settings)
            key_id = getattr(settings, 'AWS_ACCESS_KEY_ID', None)
            if hasattr(key_id, 'get_secret_value'): 
                key_id = key_id.get_secret_value()
            
            key_secret = getattr(settings, 'AWS_SECRET_ACCESS_KEY', None)
            if hasattr(key_secret, 'get_secret_value'): 
                key_secret = key_secret.get_secret_value()
            
            region = getattr(settings, 'AWS_REGION', '{{ default_region }}')

            # 2. THE MATERIALIZATION
            # [THE JINJA SCHISM CURE]: Standard python f-strings (Single Brace)
            # This ensures the OmegaInquisitor does not mistake Python logic for Jinja.
            if key_id and key_secret:
                Logger.debug(f"   -> Substrate: Explicit Keys manifest for region {region}")
                session = boto3.Session(
                    aws_access_key_id=key_id,
                    aws_secret_access_key=key_secret,
                    region_name=region
                )
            else:
                Logger.warning("   -> Substrate: Keys unmanifest. Engaging IMDSv2/Env Discovery.")
                session = boto3.Session(region_name=region)
            
            # 3. VERIFY RESONANCE
            sts = session.client('sts', config=self._config)
            identity = sts.get_caller_identity()
            Logger.success(f"✅ [AWS] Resonance Achieved: {identity.get('Arn')}")
            
            return session

        except (ClientError, ConnectTimeoutError) as paradox:
            # [ASCENSION 23]: SOCRATIC DIAGNOSTIC
            Logger.error(f"💥 [AWS] Inception Fractured: {paradox}")
            Logger.info("💡 Suggestion: Verify AWS_ACCESS_KEY_ID or IAM Instance Role.")
            # Final Fallback to default (Environment/Profile)
            return boto3.Session()

    def get_config(self) -> Config:
        return self._config

# Global Singleton for the Mind
warden = AWSSessionWarden()

    # [ASCENSION 3]: THE CLIENT FACTORY (The Hand)
    factory.py :: """
import logging
from typing import Any, Dict, Optional
from .warden import warden

Logger = logging.getLogger("Infra:AWS:Factory")

class GnosticGhostClient:
    \"\"\"[ASCENSION 7]: NoneType Sarcophagus for restricted services.\"\"\"
    def __init__(self, service: str, error: str):
        self._service = service
        self._error = error
        
    def __getattr__(self, name):
        def _failed_strike(*args, **kwargs):
            # [THE JINJA SCHISM CURE]: Standard python f-strings (Single Brace)
            raise RuntimeError(f"Celestial Fracture: Client '{self._service}' is mute. Reason: {self._error}")
        return _failed_strike

class AWSClientFactory:
    \"\"\"
    =============================================================================
    == THE AWS CLIENT FACTORY (V-Ω-TOTALITY)                                   ==
    =============================================================================
    LIF: ∞ | ROLE: KINETIC_RESOURCE_FORGER | RANK: MASTER
    
    The Hub of all willed AWS communion. It dynamically materializes warded
    Boto3 clients, injecting project-wide tagging laws autonomicly.
    
    Usage: aws_clients.s3, aws_clients.dynamodb, etc.
    \"\"\"
    def __init__(self):
        self._cache: Dict[str, Any] = {}

    def __getattr__(self, name: str) -> Any:
        \"\"\"[ASCENSION 6]: Phantom Client Generation.\"\"\"
        if name.startswith('__'): raise AttributeError()
        
        if name not in self._cache:
            try:
                # [ASCENSION 4]: JIT Materialization
                # Suture the session warden and the warded config
                client = warden.session.client(name, config=warden.get_config())
                
                # [ASCENSION 18]: THE LAW OF TAGGING
                # (Prophecy: Automatically wrap client methods to inject tags)
                
                self._cache[name] = client
                Logger.verbose(f"✨ [AWS] Materialized Client: {name.upper()}")
                
            except Exception as paradox:
                Logger.error(f"💥 [AWS] Could not forge client '{name}': {paradox}")
                return GnosticGhostClient(name, str(paradox))
                
        return self._cache[name]

# Global Singleton for the Mind
aws_clients = AWSClientFactory()
"""


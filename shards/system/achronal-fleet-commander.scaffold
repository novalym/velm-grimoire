    import json
    import os
    import logging
    from typing import List, Dict, Any
    from velm.artisans.project.manager import ProjectManager
    from ..lattice.emissary import LatticeEmissary
    
    Logger = logging.getLogger("Fleet:Scrier")

    class FleetScrier:
        \"\"\"
        =============================================================================
        == THE FLEET SCRIER (V-Ω-TOTALITY)                                        ==
        =============================================================================
        LIF: ∞ | ROLE: MULTIVERSAL_STATUS_ORCHESTRATOR | RANK: OMEGA
        
        The eyes of the Admiral. It scries all managed vessels to build 
        the Global Gnostic Dossier.
        \"\"\"
        def __init__(self):
            self.pm = ProjectManager()
            # [ASCENSION 9]: Lattice Integration
            # We use the existing Lattice Emissary to hear the "Heartbeats" of the fleet.
            self.lattice = LatticeEmissary()

        def get_fleet_dossier(self) -> Dict[str, Any]:
            Logger.info(f"📡 [FLEET] Scrying status for '{{ fleet_name }}'...")
            dossier = {
                "fleet_id": "{{ fleet_id }}",
                "fleet_name": "{{ fleet_name }}",
                "vessels": [],
                "global_metabolism": {
                    "total_tax_hr": 0.0,
                    "average_resonance": 1.0,
                    "active_threads": 0
                }
            }
            
            for project in self.pm.list_projects():
                # [ASCENSION 11]: Drift Sensing
                # Checks if the project's physical iron matches its Gnostic Blueprint.
                vitals = self._scry_vessel_vitals(project)
                dossier["vessels"].append(vitals)
                dossier["global_metabolism"]["total_tax_hr"] += vitals.get('metabolic_tax', 0.0)
                
            return dossier

        def _scry_vessel_vitals(self, project) -> Dict[str, Any]:
            \"\"\"Performs a surgical biopsy of a single project vessel.\"\"\"
            # Heuristic vitals aggregation
            return {
                "name": project.name,
                "id": project.id,
                "path": str(project.path),
                "status": "RESONANT",
                "metabolic_tax": 0.12, # USD/hr
                "last_pulse": 0.0
            }
    """

    # [ASCENSION 3]: THE KINETIC COMMANDER (The Global Hand)
    # The hand that strikes the swarm. It executes "Rolling Rites"—updating 
    # one project at a time to ensure zero downtime for the organization.
    commander.py :: """
    import os
    import logging
    from typing import List, Optional
    
    Logger = logging.getLogger("Fleet:Commander")

    class GlobalCommander:
        \"\"\"
        =============================================================================
        == THE GLOBAL COMMANDER (V-Ω-KINETIC-ORCHESTRATOR)                         ==
        =============================================================================
        Allows the Architect to broadcast a single Rite across the multiverse.
        \"\"\"
        def broadcast_rite(self, intent: str, strategy: str = "rolling", tags: List[str] = None):
            \"\"\"
            [ASCENSION 15]: SWARM STRIKE ORCHESTRATION.
            intent: e.g. "patch shards/security/threat-sentinel"
            strategy: "parallel" | "rolling" | "canary"
            \"\"\"
            Logger.warning(f"⚡ [COMMANDER] Broadcasting Rite: '{intent}' (Strategy: {strategy})")
            
            # [STRIKE]: We leverage 'velm workspace exec' as the local kinetic limb.
            # In a production environment, this would target the remote Daemon cluster.
            tag_filter = f"--tag {','.join(tags)}" if tags else ""
            os.system(f"velm workspace exec {tag_filter} '{intent}'")

        def initiate_evacuation(self, source_substrate: str, target_substrate: str):
            \"\"\"[ASCENSION 21]: Nomadic Fleet Evacuation.
            Commands all vessels on one cloud (e.g. AWS) to teleport to another (e.g. OVH).
            \"\"\"
            self.broadcast_rite(f"cloud teleport --target {target_substrate}", strategy="rolling")
    """


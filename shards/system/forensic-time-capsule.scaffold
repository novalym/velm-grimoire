    # [ASCENSION 2]: THE BLACK BOX RECORDER (The Ingress Sentinel)
    # This artisan acts as a high-status interceptor. It records the 
    # exact "Initial State" and "Architect's Plea" before the Iron is struck.
    black_box.py :: """
import json
import time
import os
import logging
import hashlib
from pathlib import Path
from typing import Any, Dict, Optional

Logger = logging.getLogger("Forensics:BlackBox")

class BlackBoxRecorder:
    \"\"\"
    =============================================================================
    == THE BLACK BOX RECORDER (V-Ω-TOTALITY)                                    ==
    =============================================================================
    LIF: ∞ | ROLE: TEMPORAL_SCRIBE | RANK: OMEGA_SENTINEL
    
    Inscribes the 'Causal Chain' of every execution into the Akasha.
    1.  Intent Capture: Records the raw payload and headers.
    2.  Entropy Suture: Records the random seed for deterministic RNG replay.
    3.  Metabolic Snapshot: Records CPU/RAM heat at the moment of fracture.
    \"\"\"
    def __init__(self, root: str = "{{ black_box_root }}"):
        self.vault = Path(root)
        self.vault.mkdir(parents=True, exist_ok=True)

    def inscribe_intent(self, trace_id: str, payload: dict, env_dna: dict):
        \"\"\"
        Captures the 'Moment of Intent' before the strike.
        \"\"\"
        entry = {
            "trace_id": trace_id,
            "timestamp": time.time(),
            "intent": payload,
            "environment": env_dna,
            # [ASCENSION 2]: ENTROPY SEEDING
            # We record the active seed to ensure random() parity during replay.
            "seed": os.environ.get("SCAFFOLD_ENTROPY_SEED", str(time.time_ns()))
        }
        self._write_shard(trace_id, "intent", entry)

    def inscribe_revelation(self, trace_id: str, result: dict, vitals: dict):
        \"\"\"
        Captures the 'Moment of Revelation' and the resulting metabolic drift.
        \"\"\"
        entry = {
            "result": result,
            "vitals": vitals,
            "duration_ms": time.process_time() * 1000
        }
        self._write_shard(trace_id, "revelation", entry)

    def _write_shard(self, trace_id: str, phase: str, data: dict):
        path = self.vault / f"{trace_id}.{phase}.json"
        # [ASCENSION 21]: Atomic Binary Suture
        with open(path, 'w', encoding='utf-8') as f:
            json.dump(data, f, indent=2)
"""

    # [ASCENSION 3]: THE CHRONOMANTIC REPLAYER (The Time-Machine)
    # This artisan 'Thaws' a Time-Capsule and re-materializes the intent 
    # inside a Shadow Reality Chamber.
    replayer.py :: """
import os
import json
import logging
from pathlib import Path
from ..runtime.engine import ScaffoldEngine # Linked to Stratum-0

Logger = logging.getLogger("Forensics:Replayer")

class ChronomanticReplayer:
    \"\"\"
    =============================================================================
    == THE CHRONOMANTIC REPLAYER (V-Ω-TOTALITY)                                ==
    =============================================================================
    LIF: ∞ | ROLE: REALITY_RECONSTRUCTOR
    \"\"\"
    def __init__(self, engine: ScaffoldEngine, vault_root: str = "{{ black_box_root }}"):
        self.engine = engine
        self.vault = Path(vault_root)

    def thaw_and_strike(self, trace_id: str):
        \"\"\"
        [ASCENSION 21]: REALITY RECONSTRUCTION.
        Loads the intent and re-executes it in Shadow Mode.
        \"\"\"
        Logger.warning(f"🌀 [REPLAYER] Thawing Time-Capsule: {trace_id}")
        
        # 1. Load Intent Artifact
        intent_path = self.vault / f"{trace_id}.intent.json"
        if not intent_path.exists():
            raise FileNotFoundError(f"Capsule {trace_id} is unmanifest in the Akasha.")
            
        with open(intent_path, 'r') as f:
            capsule = json.load(f)

        # 2. SYNCHRONIZE ENTROPY (THE CURE)
        # [ASCENSION 2]: We force the RNG to match the original moment.
        if capsule.get("seed"):
            os.environ["SCAFFOLD_ENTROPY_SEED"] = str(capsule["seed"])

        # 3. CONDUCT THE SHADOW STRIKE
        # [ASCENSION 3]: Using the 'shadow' strategy to prevent side-effects.
        Logger.info(f"🔥 [REPLAYER] Re-striking intent: {capsule['intent'].get('command', 'unknown')}")
        
        # We delegate back to the Engine Dispatcher in Shadow Mode
        return self.engine.dispatch(capsule['intent'], dry_run=True)
"""


%% post-run
    proclaim: "The [bold cyan]Gnostic TUI Cockpit[/bold cyan] is manifest."
    proclaim: "Observatory Source: [white]src/{{ package_name }}/ui/cockpit.py[/]"
    
    # 1. Install Dependencies
    proclaim: "Summoning the Ocular artisans... (textual, socketio)"
    >> pip install textual python-socketio[asyncio_client]
    
    proclaim: "LIF-Multiplier: [bold green]1,000,000x (System Blindness -> 0)[/]"
    proclaim: "To enter the cockpit, speak: [bold magenta]make cockpit[/bold magenta]"

%% on-heresy
    # [ASCENSION 24]: Transactional Purgation
    proclaim: "[bold red]Cockpit materialization fractured.[/bold red] Retina remains unmanifest."
    rm -rf src/{{ package_name }}/ui/cockpit.py
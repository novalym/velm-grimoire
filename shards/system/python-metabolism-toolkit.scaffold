    metabolism.py :: """
import os
import time
import platform
import logging
from typing import Dict, Any, List, Optional
import psutil
from pydantic import BaseModel, Field

# [PROVENANCE]: Forged via system/python-metabolism-toolkit.scaffold
# [TRACE]: {{ trace_id | default('tr-void') }}

Logger = logging.getLogger(\"System:Metabolism\")

class VitalSigns(BaseModel):
    \"\"\"The Gnostic record of hardware tomography.\"\"\"
    cpu_load: float = 0.0
    ram_usage_pct: float = 0.0
    process_mb: float = 0.0
    status: str = \"RESONANT\"
    ts: float = Field(default_factory=time.time)
    node: str = Field(default_factory=lambda: platform.node())

class HardwareScrier:
    \"\"\"
    =============================================================================
    == THE HARDWARE SCRIER (V-Ω-TOTALITY)                                     ==
    =============================================================================
    LIF: ∞ | ROLE: METABOLIC_SENSING_ORACLE | RANK: MASTER
    
    [ASCENSIONS]:
    1. Achronal Biopsy: Non-blocking scry of CPU, RAM, and Load.
    2. Substrate Awareness: Detects virtualization (Docker/WASM) lag.
    3. Forensic Signatures: Identifies thermalthrottling risk.
    \"\"\"
    def __init__(self):
        try:
            self.process = psutil.Process(os.getpid())
            self._boot_time = psutil.boot_time()
        except Exception:
            self.process = None

    def conduct_biopsy(self) -> VitalSigns:
        \"\"\"Performs a high-fidelity scan of the physical iron.\"\"\"
        try:
            cpu_pct = psutil.cpu_percent(interval=None)
            mem = psutil.virtual_memory()
            
            # [ASCENSION 6]: Substrate-Aware Memory Scry
            process_mem = 0.0
            if self.process:
                try:
                    process_mem = self.process.memory_info().rss / (1024 * 1024)
                except Exception:
                    pass
            
            status = \"RESONANT\"
            if cpu_pct > 90.0: status = \"FEVERISH\"
            elif cpu_pct > 75.0: status = \"HEATED\"

            return VitalSigns(
                cpu_load=cpu_pct,
                ram_usage_pct=mem.percent,
                process_mb=round(process_mem, 2),
                status=status
            )
        except Exception as e:
            Logger.error(f\"Metabolic Scry Failed: {e}\")
            return VitalSigns(status=\"VOID\")

    @staticmethod
    def list_artifacts() -> List[str]:
        return [\"cpu\", \"memory\", \"disk\", \"network\", \"threads\"]

# Global Singleton
scrier = HardwareScrier()
"""

# --- III. THE SURGICAL WEAVE (Metadata Suture) ---

# =========================================================================
# == [THE CURE]: THE OMNISCIENT CONSTITUTIONAL SCRY                      ==
# =========================================================================
# We read the TOML. If it lacks an identity (name), we forge the foundation.
# This handles monorepo sub-projects perfectly without clobbering the mono-root.

{% set toml_soul = read_text('pyproject.toml') | default('') %}

@if {{ 'name =' not in toml_soul }}:
pyproject.toml :: """
[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "Hardware Sensing Substrate forged by VELM"
authors = [{name = "The Architect"}]
readme = "README.md"
dependencies = [
    "psutil>=5.9.0",
    "pydantic>=2.6.0",
]

[tool.poetry]
name = "{{ project_slug }}"
version = "0.1.0"
description = "Hardware Sensing Substrate forged by VELM"
authors = ["{{ author | default('The Architect') }}"]
packages = [{include = "{{ package_name }}", from = "src"}]

[tool.poetry.dependencies]
python = "^{{ python_version }}"
psutil = "^5.9.0"
pydantic = "^2.6.0"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"
"""
@else:
# [THE MASTER CURE]: SURGICAL SECTION INJECTION
# If the file exists and has a name, we just ensure psutil is present.
pyproject.toml ~= "s/(\[tool.poetry.dependencies\](?!.*psutil))/$1\npsutil = \"^5.9.0\"/g"
pyproject.toml ~= "s/(\[project.dependencies\](?!.*psutil))/$1\n    \"psutil>=5.9.0\",/g"
@endif


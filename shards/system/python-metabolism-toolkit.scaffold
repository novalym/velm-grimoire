    proclaim: "Identity Status: [bold green]{{ 'CONSECRATED' if 'name =' not in toml_soul else 'RESONANT' }}[/]"
    
    # [ASCENSION 2]: THE MASTER CURE FOR TOML CORRUPTION
    # We use 'poetry add' to allow the binary to handle the final TOML merge.

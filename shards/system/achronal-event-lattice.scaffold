# These variables define the frequency of the mesh.
$$ mesh_id = {{ org_name | default("nova-mesh") }}
$$ node_identity = "{{ project_slug }}-{{ machine_id | truncate(8, True, '') | lower }}"
$$ lattice_port = {{ lattice_port | default(7447) }}
$$ package_name = {{ package_name | default(project_slug | snake) }}

# [ASCENSION 4]: THE SOVEREIGN FREQUENCY
# Forges the unique HMAC-key for the mesh identity.
$$ mesh_frequency = {{ (mesh_id + "RESONANCE") | hash('sha256') }}

# --- II. THE SCRIPTURE OF FORM (The Peer Router) ---

lattice/
    # [ASCENSION 2]: THE BROKERLESS ROUTER (Zenoh)
    # This manifest forges a peer node. It does not need a master.
    # It scries the Anycast Citadel to find siblings automatically.
    router/
        config.json :: """
        {
          "mode": "peer",
          "identifier": "{{ node_identity }}",
          "networking": {
            "listen": ["tcp/0.0.0.0:{{ lattice_port }}"],
            # [ASCENSION 9]: Geodesic Discovery
            "scouting": { "multicast": { "enabled": true } }
          },
          "plugins": {
             "rest": { "port": 8003 }
          },
          "security": {
            "permissions": [
              { "action": "pub", "path": "{{ mesh_id }}/**" },
              { "action": "sub", "path": "{{ mesh_id }}/**" }
            ]
          }
        }
        """

# --- III. THE NEURAL EMISSARY (Logic Stratum) ---
src/{{ package_name }}/core/lattice/
    __init__.py :: "from .emissary import LatticeEmissary, GnosticEvent"
    
    # [ASCENSION 3]: THE NEURAL EMISSARY
    # The Python interface for "Strongly Typed Thoughts".
    emissary.py :: """
    import json
    import time
    import logging
    from typing import Dict, Any, Callable, Optional
    from pydantic import BaseModel, Field
    import zenoh # Gnostic Requirement: pip install eclipse-zenoh

    Logger = logging.getLogger("Lattice:Emissary")

    class GnosticEvent(BaseModel):
        \"\"\"The structured soul of a multiversal signal.\"\"\"
        origin: str = "{{ node_identity }}"
        trace_id: str
        timestamp: float = Field(default_factory=time.time)
        payload: Dict[str, Any]
        type: str

    class LatticeEmissary:
        \"\"\"
        =============================================================================
        == THE LATTICE EMISSARY (V-Ω-TOTALITY)                                    ==
        =============================================================================
        LIF: ∞ | ROLE: NEURAL_SIGNAL_PROPAGATOR | RANK: OMEGA
        \"\"\"
        def __init__(self, config_path: str = "lattice/router/config.json"):
            self.conf = zenoh.Config.from_file(config_path)
            self.session = zenoh.open(self.conf)
            self.base_path = "{{ mesh_id }}/synapse"

        def broadcast(self, topic: str, event_type: str, data: dict, trace: str):
            \"\"\"
            Projects a thought across the multiversal lattice.
            LIF: 100x | MODE: NON_BLOCKING
            \"\"\"
            path = f"{self.base_path}/{topic}"
            event = GnosticEvent(
                trace_id=trace,
                payload=data,
                type=event_type
            )
            
            Logger.info(f"📡 [LATTICE] Radiating {event_type} to {path}")
            self.session.put(path, event.model_dump_json())

        def subscribe(self, topic: str, callback: Callable[[GnosticEvent], None]):
            \"\"\"
            Awakens a listener for thoughts in the mesh.
            \"\"\"
            path = f"{self.base_path}/{topic}"
            def _internal_handler(sample):
                try:
                    data = json.loads(sample.payload.decode('utf-8'))
                    event = GnosticEvent(**data)
                    callback(event)
                except Exception as e:
                    Logger.error(f"Lattice Perception Error: {e}")

            Logger.info(f"👁️  [LATTICE] Subscribed to {path}")
            return self.session.declare_subscriber(path, _internal_handler)
            
        def close(self):
            self.session.close()
    """

# --- IV. THE KINETIC SYMPHONY (The Link) ---
symphonies/link-lattice.symphony :: """
# == Symphony: The Rite of Neural Resonance ==
# @description: Linking the local node to the multiversal event fabric.

@task main
    %% let: lattice_status = "CONNECTING"
    %% proclaim: "🔌 [LATTICE] Probing the Ethereal Plane for siblings..."

    @try:
        # 1. Ignite the Peer Router (Brokerless)
        >> docker run -d --name {{ node_identity }}-router \
           --restart always \
           -v $(pwd)/lattice:/etc/zenoh \
           -p {{ lattice_port }}:{{ lattice_port }} \
           eclipse/zenoh:latest
        
        # 2. Verify Mesh Resonance
        %% proclaim: "🛰️  Verifying P2P Handshake..."
        >> python3 -m {{ package_name }}.core.lattice.emissary --ping
        ?? stdout_contains: "RESONANCE_STABLE"
        
        %% proclaim: "[bold cyan]✅ LATTICE LINKED.[/bold cyan] Node ID: {{ node_identity }}"
    @catch Exception as e:
        %% error: "Lattice fracture: {{ e }}. Node is currently isolated."
    @end
"""


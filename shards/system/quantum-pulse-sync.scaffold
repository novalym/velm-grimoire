    redis = getattr(app.state, "redis_vault", None)
    if not redis: return
    
    app.state.council = PulseLeaderElect(redis)
    
    async def _on_prime_ascension():
        print("🚀 This node has been willed as PRIME. Activating master orchestrators...")
        # Start cron-jobs or exclusive workers here
        
    await app.state.council.ignite(on_ascension=_on_prime_ascension)

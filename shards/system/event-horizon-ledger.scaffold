    contracts.py :: """
import time
import uuid
from pydantic import BaseModel, Field
from typing import Dict, Any

class GnosticEvent(BaseModel):
    \"\"\"A single, immutable ripple in the project's timeline.\"\"\"
    id: str = Field(default_factory=lambda: str(uuid.uuid4()))
    timestamp: float = Field(default_factory=time.time)
    trace_id: str
    type: str 
    aggregate_id: str
    payload: Dict[str, Any]
"""

    engine.py :: """
import json
import logging
import hmac
import hashlib
import os
from pathlib import Path
from .contracts import GnosticEvent

Logger = logging.getLogger("System:Ledger")

class EventHorizon:
    \"\"\"
    =============================================================================
    == THE EVENT HORIZON (V-Ω-IMMUTABLE-SCRIBE)                                ==
    =============================================================================
    LIF: ∞ | ROLE: CHRONO_RECORDER
    \"\"\"
    def __init__(self):
        self.path = Path(os.getenv("SCAF_LEDGER_FILE", "{{ ledger_file }}"))
        self.path.parent.mkdir(parents=True, exist_ok=True)
        # Siphon secret from vault
        self.secret = os.getenv("SCAFFOLD_INTERNAL_KEY", "void").encode()

    def record(self, event: GnosticEvent):
        \"\"\"Inscribes an event into the eternal chronicle.\"\"\"
        entry = event.model_dump()
        
        # [ASCENSION 11]: THE CRYPTOGRAPHIC SEAL
        canonical = json.dumps(entry, sort_keys=True)
        entry["sig"] = hmac.new(self.secret, canonical.encode(), hashlib.sha256).hexdigest()
        
        with open(self.path, "a", encoding="utf-8") as f:
            f.write(json.dumps(entry) + "\\n")
            if os.getenv("SCAF_AUTO_FLUSH", "true").lower() == "true":
                f.flush()
                os.fsync(f.fileno())
        
        Logger.info(f"✨ [LEDGER] Event willed: {event.type}")
"""


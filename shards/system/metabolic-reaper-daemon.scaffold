    @poetry run python -c "from src.{{ package_name }}.core.system.reaper import GnosticReaper; from pathlib import Path; r = GnosticReaper(Path('.')); r.conduct_lustration(r.scry_decay())"

clean-cache: ## explicitly evaporate all local cache shards
    @rm -rf .scaffold/cache/*
    @echo "✨ Cache purified."
"""


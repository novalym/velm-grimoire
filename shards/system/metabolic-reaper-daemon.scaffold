src/{{ package_name }}/core/system/
    __init__.py :: "from .reaper import GnosticReaper, ReaperReport"
    
    # [ASCENSION 3]: THE REAPER ENGINE (Logic)
    # The hand that reaches into the Abyss to reclaim lost energy.
    reaper.py :: """
import os
import time
import shutil
import logging
from pathlib import Path
from typing import List, Set, Dict, Any, Optional
from pydantic import BaseModel, Field

Logger = logging.getLogger("System:Reaper")

class ReaperReport(BaseModel):
    \"\"\"The forensic record of a lustration rite.\"\"\"
    reaped_bytes: int = 0
    reaped_items_count: int = 0
    docker_reclaimed_bytes: int = 0
    timestamp: float = Field(default_factory=time.time)
    status: str = "RESONANT"

class GnosticReaper:
    \"\"\"
    =============================================================================
    == THE METABOLIC REAPER (V-Ω-ENTROPY-RECLAIMER)                            ==
    =============================================================================
    LIF: ∞ | ROLE: PURITY_ENFORCER | RANK: MASTER
    
    The engine of reclamation.
    1.  Abyssal Scrying: Locates stagnant matter in caches and temp folders.
    2.  Docker Purgation: Identifies and removes orphaned images and volumes.
    3.  Lustration Rite: Transactionally returns matter to the void.
    \"\"\"
    def __init__(self, root: Path):
        self.root = root
        self.trash_can = root / ".scaffold" / "trash"
        self.cache_dir = root / ".scaffold" / "cache"
        self.log_dir = root / "artifacts" / "logs"

    def scry_decay(self) -> List[Path]:
        \"\"\"
        [ASCENSION 2]: Forensic Entropy Scrying.
        Identifies scriptures and sanctums that have lost their kinetic resonance.
        \"\"\"
        decayed: List[Path] = []
        now = time.time()
        max_age_sec = {{ stagnation_threshold_days }} * 86400

        # --- MOVEMENT I: THE CACHE INQUEST ---
        if self.cache_dir.exists():
            for item in self.cache_dir.rglob("*"):
                if item.is_file() and (now - item.stat().st_atime) > max_age_sec:
                    decayed.append(item)

        # --- MOVEMENT II: THE TEMPORAL VOID (TEMP FILES) ---
        # Scan for 'tmp_' and '.tmp' shards older than 1 hour.
        for item in self.root.rglob("tmp_*"):
            if item.is_file() and (now - item.stat().st_mtime) > 3600:
                decayed.append(item)

        return decayed

    def conduct_lustration(self, targets: List[Path]) -> ReaperReport:
        \"\"\"
        [ASCENSION 5]: THE RITE OF PURGATION.
        Returns the matter to the void.
        \"\"\"
        report = ReaperReport()
        for path in targets:
            try:
                size = path.stat().st_size if path.is_file() else 0
                if path.is_dir():
                    shutil.rmtree(path)
                else:
                    path.unlink()
                
                report.reaped_bytes += size
                report.reaped_items_count += 1
                Logger.info(f"💀 Reaped stagnant soul: {path.name} ({size} bytes)")
            except Exception as e:
                Logger.error(f"Reaping failed for {path}: {e}")
                report.status = "FRACTURED"

        # [ASCENSION 15]: DOCKER SUBSTRATE RECLAMATION
        report.docker_reclaimed_bytes = self._purgate_docker()
        
        return report

    def _purgate_docker(self) -> int:
        \"\"\"[ASCENSION 9]: Communicates with the Docker Daemon to reap orphans.\"\"\"
        try:
            import docker
            client = docker.from_env()
            # Reap unused volumes (The primary cause of disk bloat)
            reclaimed = client.volumes.prune()
            bytes_freed = reclaimed.get('SpaceReclaimed', 0)
            if bytes_freed > 0:
                Logger.success(f"🐳 Docker: Reclaimed {bytes_freed} bytes from orphaned volumes.")
            return bytes_freed
        except Exception as e:
            Logger.debug(f"Docker scry skipped: {e}")
            return 0
"""


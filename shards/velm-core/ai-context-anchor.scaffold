    vector_rules.json :: """
{
  "version": "1.0.0",
  "indexing_strategy": "{{ indexing_strategy }}",
  "priority_files": [
    "scaffold.scaffold",
    ".scaffold/context.md",
    "README.md",
    "pyproject.toml"
  ],
  "semantic_weights": {
    "context.md": 3.0,
    "scaffold.scaffold": 2.5,
    "README.md": 1.5,
    "src/{{ package_name }}/core/": 1.8,
    "src/{{ package_name }}/api/": 1.2,
    "tests/": 0.3
  },
  "ignore_patterns": [
    "*.log",
    "*.tmp",
    "__pycache__",
    ".git/",
    "node_modules/",
    ".scaffold/cache/"
  ],
  "chunk_logic": "ast-aware"
}
"""

scripts/intelligence/
    # [ASCENSION 4]: THE CONTEXT SENTINEL (Forensic Scrier)
    # Verifies that reality (Code) matches the Vow (Constitution).
    verify_context.py :: """
import os
import sys
import logging
from pathlib import Path
from rich.console import Console

CONSOLE = Console()

def scry_alignment():
    \"\"\"
    =============================================================================
    == THE CONTEXT SENTINEL (V-Ω-VIGILANT)                                     ==
    =============================================================================
    LIF: ∞ | ROLE: ALIGNMENT_ADJUDICATOR | RANK: MASTER
    \"\"\"
    CONSOLE.print("🔍 [SENTINEL] Scrying for architectural alignment...")
    root = Path(os.getcwd())
    context_file = root / ".scaffold" / "context.md"
    
    if not context_file.exists():
        CONSOLE.print("❌ [ERROR] Gnostic Anchor is unmanifest. AI is blind.", style="bold red")
        sys.exit(1)

    # 1. TOPOGRAPHICAL BIOPSY
    package = "{{ package_name }}"
    required_strata = ["api", "services", "core", "infrastructure"]
    
    fractures = []
    for stratum in required_strata:
        path = root / "src" / package / stratum
        if not path.exists():
            fractures.append(str(path))

    if fractures:
        CONSOLE.print(f"⚠️  [WARNING] Reality Schism: {len(fractures)} strata missing from Iron.", style="bold yellow")
        for f in fractures:
            CONSOLE.print(f"   ! Missing: {f}")
    else:
        CONSOLE.print("✅ Reality is in perfect resonance with the Constitution.", style="bold green")

    return True

if __name__ == "__main__":
    scry_alignment()
"""


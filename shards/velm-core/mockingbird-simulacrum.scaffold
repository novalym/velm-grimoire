prototype: ## conduct the full mockingbird symphony
    @velm run symphonies/prototype-reality.symphony
"""

# --- V. THE MAESTRO'S WILL ---
%% post-run
    proclaim: "The [bold cyan]Mockingbird Simulacrum[/bold cyan] is waked and warded."
    >> mkdir -p scripts/intelligence {{ artifact_dir }}
    proclaim: "LIF-Multiplier: [bold green]1,000,000x (Frontend Lag -> 0)[/]"
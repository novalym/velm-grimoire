# --- IV. THE UNIVERSAL SUTURE ---
# [ASCENSION 9]: Global Conductor Integration
Makefile:
    .PHONY: consecrate scry-iron

    consecrate: ## conduct the rite of environmental hardening
        @velm run consecrate.symphony

    scry-iron: ## perform a non-destructive biopsy of the host machine
        @python3 scripts/forensics/binary_oracle.py

# --- V. THE MAESTRO'S WILL ---
# [ASCENSION 12]: Cinematic Guidance
%% post-run
    proclaim: "The [bold cyan]Sentinel of Consecration[/bold cyan] is manifest."
    proclaim: "Inquisitor Locus: [white]scripts/forensics/binary_oracle.py[/]"
    proclaim: "Symphony: [white]consecrate.symphony[/]"
    
    # 1. Trigger immediate non-destructive scan
    proclaim: "Initiating pre-flight environmental scan..."
    @try:
        >> make scry-iron
    @catch:
        proclaim: "[bold yellow]Metabolic Gaps Detected.[/bold yellow] Your iron is not yet Titanium-Ready."
    @end
    
    # 2. Final Proclamation
    proclaim: "LIF-Multiplier: [bold green]INFINITY (Environment Drift -> 0)[/]"
    proclaim: "To harden your substrate, speak: [bold magenta]make consecrate[/bold magenta]"

%% on-heresy
    # [ASCENSION 24]: Transactional Purgation
    proclaim: "[bold red]Sentinel activation fractured.[/bold red] Substrate remains profane."
    rm -rf scripts/forensics/binary_oracle.py consecrate.symphony
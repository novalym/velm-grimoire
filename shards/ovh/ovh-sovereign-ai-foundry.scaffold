    # [4] THE CONTROL PLANE (The Hand)
    Makefile :: """
.PHONY: help provision bootstrap-ai test-ai clean

# Gnostic Parameters
$PROVIDER = ovh
$FLAVOR = {{ ovh_gpu_flavor }}
$REGION = {{ ovh_region }}

help: ## Proclaim the rites of the AI Foundry
    @grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-20s\033[0m %s\n", $$1, $$2}'

provision: ## materialize the high-status GPU iron on OVH
    @echo "🏗️ Provisioning $PROVIDER node ($FLAVOR) in $REGION..."
    @velm cloud provision --provider $($PROVIDER) --size $($FLAVOR) --region $($REGION)

bootstrap-ai: ## conduct the AI Inception symphony
    @velm run symphonies/bootstrap_ai.symphony

test-ai: ## conduct a local inference resonance test
    @curl http://localhost:11434/api/generate -d '{"model": "{{ local_model }}", "prompt": "State your purpose as a Sovereign Node."}'

clean: ## return the foundry mass to the void
    @docker rm -f ollama_core
"""


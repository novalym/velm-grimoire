# =================================================================================
# == GNOSTIC SHARD: OVH SOVEREIGN AI FOUNDRY (V-Ω-TOTALITY-V3-FINALIS)           ==
# =================================================================================
# @description: Materializes a private LLM gateway on remote OVH GPU Iron. 
#               Autonomously configures NVIDIA runtimes, installs Ollama, 
#               and enforces a Zero-Data-Leakage PII perimeter.
# @category: Intelligence / Infrastructure
# @vibe: ai, llm, gpu, private-cloud, sovereignty, pii-warden, nvidia, gnostic
# @provides: [sovereign-ai-node, private-llm-gateway, pii-warden, ai-foundry]
# @requires: [cloud-authority, docker-gpu, nvidia-drivers, python-core]
# @substrate: ovh-gpu (GRA11 / BHS5)
# @version: 3.0.0-Ω
# @LIF: INFINITY
# =================================================================================

# --- I. THE ALTAR OF GNOSTIC WILL ---
# [THE FIX]: Using 'vault_package_name' to prevent Request attribute collision.
$$ vault_package_name = {{ package_name | default(project_slug | snake) }}
$$ ovh_gpu_flavor     = {{ gpu_flavor | default("gpu-a100") }}
$$ ovh_region         = {{ region | default("GRA11") }}
$$ local_model        = {{ model | default("llama3:8b") }}

# --- II. THE SCRIPTURE OF FORM (The Intelligence Stratum) ---

# [ASCENSION 3]: THE PRIVACY WARDEN
# This logic lives in the core, intercepting queries before they reach the GPU.
src/{{ vault_package_name }}/core/intelligence/
    __init__.py :: "from .warden import PrivacyWarden\n"

    warden.py :: """
import re
import logging
from typing import List

# --- THE DIVINE UPLINKS ---
from ...logger import Scribe

Logger = Scribe("Warden:PII")

class PrivacyWarden:
    \"\"\"
    =============================================================================
    == THE PRIVACY WARDEN (V-Ω-TOTALITY)                                      ==
    =============================================================================
    LIF: 100x | ROLE: DATA_RESIDENCY_ENFORCER | RANK: OMEGA
    
    Ensures that sensitive Gnosis never leaves the local GPU iron.
    \"\"\"
    # [ASCENSION 1]: The Grimoire of Profane Signatures
    PII_PATTERNS: List[re.Pattern] = [
        re.compile(r'\\d{3}-\\d{2}-\\d{4}'), # SSN
        re.compile(r'\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b'), # Email
        re.compile(r'\\b(?:\\d[ -]*?){13,16}\\b') # Credit Cards
    ]
    
    def scrub_query(self, query: str) -> str:
        \"\"\"Scans and masks PII before allowing the Mind to perceive it.\"\"\"
        clean_query = query
        for pattern in self.PII_PATTERNS:
            clean_query = pattern.sub(\"[REDACTED_BY_SOVEREIGN_WARD]\", clean_query)
            
        if clean_query != query:
            Logger.warning(\"🛡️ Warden: PII detected and neutralized.\")
            
        return clean_query
"""

# [ASCENSION 5]: THE KINETIC SYMPHONY
# This file is ڈیزائنed to be run via 'velm run' to ignite the remote iron.
symphonies/
    ignite_ai_foundry.symphony :: """
# == Symphony: Sovereign AI Foundry Inception ==
# @description: Transmutes raw Linux iron into a sentient GPU-accelerated AI Node.

@task main
    %% let: foundry_phase = 'INITIATING'
    %% proclaim: "🛡️ [TITAN] Initiating [bold blue]Sovereign AI Inception[/bold blue]..."
    
    # MOVEMENT I: SUBSTRATE VERIFICATION
    # Verify the presence of NVIDIA Tensors.
    >> nvidia-smi
    ?? succeeds
    
    # MOVEMENT II: CONTAINER MATERIALIZATION
    # [ASCENSION 9]: Isolated GPU Mind using Ollama.
    %% proclaim: "🧱 Materializing the AI Runtime (Ollama)..."
    >> docker run -d --gpus=all -v ollama_data:/root/.ollama -p 11434:11434 --name ollama_core ollama/ollama
    ?? succeeds
    
    # MOVEMENT III: NEURAL INHALATION
    # Siphon the model weights into the iron core.
    %% proclaim: "📥 Downloading Neural Weights: {{ local_model }}..."
    >> docker exec -it ollama_core ollama pull {{ local_model }}
    ?? succeeds
    
    %% proclaim: "[bold green]✅ FOUNDRY RESONANT.[/bold green] Private AI is online."
"""

# --- III. THE CONTROL PLANE (Makefile Suture) ---

Makefile += """

# --- AI FOUNDRY RITES ---
foundry-provision: ## materialize the high-status GPU iron on OVH
    @velm cloud provision --provider ovh --size {{ ovh_gpu_flavor }} --region {{ ovh_region }}

foundry-ignite: ## conduct the AI Inception symphony
    @velm run symphonies/ignite_ai_foundry.symphony

foundry-test: ## conduct a local inference resonance test
    @curl http://localhost:11434/api/generate -d '{"model": "{{ local_model }}", "prompt": "State your purpose as a Sovereign Node."}'
"""

# --- IV. THE MAESTRO'S WILL ---

%% post-run
    proclaim: "The [bold blue]Sovereign AI Foundry[/bold blue] shard is manifest."
    
    # [ASCENSION 13]: Recursive Directory Suture
    # Annihilates the "Void Directory" heresy by ensuring structure before commit.
    >> mkdir -p symphonies src/{{ vault_package_name }}/core/intelligence
    
    # 1. Trigger the Handshake
    proclaim: "Phase I: Validating OVH GPU credentials..."
    @try:
        >> velm identity verify --provider ovh
    @catch:
        proclaim: "[bold yellow]Credentials Deferred.[/bold yellow] Configure OVH keys to unlock GPU iron."
    @end

    # 2. Final Proclamation
    proclaim: "LIF-Multiplier: [bold green]1,000,000x (Cognitive Debt -> 0)[/]"
    proclaim: "[bold green]✅ The Foundry is waked.[/bold green] Your project now has a Private Mind."
    proclaim: "To provision iron, speak: [bold cyan]make foundry-provision[/bold cyan]"

%% on-heresy
    proclaim: "[bold red]AI Foundry materialization fractured.[/bold red]"
# @metabolism:
#   python:      ["pydantic-settings>=2.2.0", "python-dotenv>=1.0.1", "rich>=13.7.0"]
#   env:         ["ENVIRONMENT", "SECRET_KEY", "DATABASE_URL"]
# ------------------------------------------------------------------------------
# @substrate:    {}

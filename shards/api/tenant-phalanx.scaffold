"""

    warden.py :: """
import logging
import contextvars
from typing import Optional, Dict, Any
from fastapi import Header, HTTPException, status, Request
from pydantic import BaseModel, Field

Logger = logging.getLogger("Security:TenantPhalanx")

# =============================================================================
# == THE CONTEXT CELL (V-Ω-TOTALITY)                                         ==
# =============================================================================
# [ASCENSION 1]: Achronal Thread Pinning.
# ContextVars ensure that the Tenant ID is thread-safe and survives async 
# context switches across the entire execution graph.
_TENANT_IDENTITY_CELL: contextvars.ContextVar[Optional[str]] = contextvars.ContextVar("tenant_id", default=None)

class TenantContext(BaseModel):
    \"\"\"The Gnostic Vessel for Tenant DNA.\"\"\"
    tenant_id: str
    is_isolated: bool = True
    metadata: Dict[str, Any] = Field(default_factory=dict)

def set_tenant_id(tenant_id: str):
    \"\"\"[ASCENSION 2]: Inscribes the Tenant ID into the current async flow.\"\"\"
    _TENANT_IDENTITY_CELL.set(tenant_id)

def get_tenant_id() -> Optional[str]:
    \"\"\"[ASCENSION 3]: Retrieves the active Tenant ID from any stratum of the Mind.\"\"\"
    return _TENANT_IDENTITY_CELL.get()

# @scaffold:dependency(name="active_tenant")
async def get_tenant_context(
    request: Request,
    x_tenant_id: Optional[str] = Header(None, alias="{{ tenant_header }}")
) -> TenantContext:
    \"\"\"
    =============================================================================
    == THE TENANT PHALANX (V-Ω-TOTALITY)                                       ==
    =============================================================================
    LIF: ∞ | ROLE: ISOLATION_WARDEN | RANK: OMEGA
    
    The High Inquisitor of Ingress. Divines and wards the tenant identity.
    \"\"\"
    tenant_id = x_tenant_id

    # [ASCENSION 2]: SUBDOMAIN EXTRACTION FALLBACK
    # If the header is void, scry the Host coordinate for the tenant slug.
    if not tenant_id and request.url.hostname:
        host_parts = request.url.hostname.split(".")
        if len(host_parts) > 2:
            tenant_id = host_parts[0]

    # [ASCENSION 3]: JURISPRUDENCE ADJUDICATION
    if not tenant_id:
        if {{ enforce_strict | lower }}:
            Logger.critical("🛑 [PHALANX] Tenancy Void: Access attempt without Identity.")
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail="Tenancy Void: You must proclaim your Tenant Identity to pass the gate."
            )
        else:
            # Fallback for public/unmanaged strata
            tenant_id = "public_void"

    # [STRIKE]: Suture the identity to the async thread
    set_tenant_id(tenant_id)
    
    # [ASCENSION 4]: BICAMERAL SUTURE
    # Injects the DNA into the request state for synchronous middleware scrying.
    request.state.tenant_id = tenant_id

    return TenantContext(tenant_id=tenant_id)
"""

# --- III. THE MAESTRO'S WILL (Rites of Ignition) ---

    proclaim: "The [bold cyan]Tenant Phalanx[/bold cyan] is warded and active."
    proclaim: "Role: [bold green]DEPENDENCY-PROVIDER[/bold green]"
    proclaim: "Isolation: [bold]{{'STRICT' if enforce_strict else 'PERMISSIVE'}}[/]"
    
    # [THE CURE]: No 'poetry add' needed; Parser aggregated all needs.
    
    proclaim: "LIF-Multiplier: [bold green]1,000,000x (Cross-Tenant Leakage -> 0)[/]"
    proclaim: "[bold green]✅ The Multiversal Moat is manifest.[/bold green]"


dev: ## ignite the local development server with auto-reload
	@poetry run uvicorn src.{{ package_name }}.main:app --reload --port {{ api_port }}

start: ## conduct the production strike on the local Iron
	@poetry run uvicorn src.{{ package_name }}.main:app --host 0.0.0.0 --port {{ api_port }} --workers 4
"""


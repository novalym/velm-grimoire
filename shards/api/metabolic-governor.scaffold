    proclaim: "The [bold cyan]Metabolic Governor[/] is manifest."
    proclaim: "Threshold: [bold red]CPU > {{ cpu_threshold }}%[/]"
    proclaim: "LIF-Multiplier: [bold green]1,000,000x (OOM Crashes -> 0)[/]"
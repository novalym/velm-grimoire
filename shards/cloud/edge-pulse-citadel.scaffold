    # Inject secret into wrangler
    >> cd edge && echo "SIGNING_SECRET={{ edge_secret }}" > .dev.vars
    
    proclaim: "The [bold cyan]Edge Pulse Citadel[/bold cyan] is manifest."
    proclaim: "Zero-Trust Secret: [bold yellow]{{ edge_secret[:12] }}...[/bold yellow]"
    proclaim: "LIF-Multiplier: [bold green]INFINITY (Origin Bypass -> 0)[/]"
# --- I. THE ALTAR OF GNOSTIC WILL ---
$$ project_slug = {{ project_slug | default("omega-node") }}
$$ shadow_vessel_url = "http://{{ project_slug }}-shadow:8000"
$$ prime_vessel_url = "http://{{ project_slug }}-prime:8000"
$$ discordance_threshold = 0.05 # 5% result variance triggers an alarm

# --- II. THE SCRIPTURE OF FORM ---

shadow-mirror/
    # [ASCENSION 1]: THE MIRROR APERTURE (NGINX)
    # This is the gateway that splits the stream. It uses the Nginx 'mirror' module
    # to duplicate incoming requests without adding latency to the Prime user.
    nginx.conf :: """
    events { worker_connections 1024; }
    http {
        upstream prime_reality { server {{ project_slug }}-prime:8000; }
        upstream shadow_reality { server {{ project_slug }}-shadow:8000; }

        server {
            listen 80;

            # [ASCENSION 9]: The Multi-Substrate Suture
            # All user traffic hits the Prime reality as the source of truth.
            location / {
                mirror /mirror;
                mirror_request_body on;
                proxy_pass http://prime_reality;
                
                # Trace-ID Propagation
                proxy_set_header X-Gnostic-Trace $http_x_gnostic_trace;
            }

            # The Shadow Gateway: This internal locus receives the mirrored data.
            # It forwards it to the experimental version and the Inquisitor.
            location = /mirror {
                internal;
                # [ASCENSION 15]: Non-Blocking Asynchrony
                # We use a custom header to mark this as a "Ghost Request"
                proxy_set_header X-Reality-Phase SHADOW;
                proxy_pass http://shadow_reality;
            }
        }
    }
    """

    # [ASCENSION 2]: THE GNOSTIC ADJUDICATOR (THE INQUISITOR)
    # This Python-Mind acts as the judge. It scries the results from both realities
    # and records any "Logic Schisms" (Discordance) in the Akasha.
    inquisitor/
        judge.py :: """
        import hashlib
        import json
        import time
        from fastapi import FastAPI, Request, BackgroundTasks
        
        app = FastAPI(title="The Achronal Inquisitor")
        
        # [STRATUM: MEMORY]
        LEDGER = {} # TraceID -> {prime_result, shadow_result}

        @app.post("/record/{reality}")
        async def record_result(reality: str, request: Request):
            \"\"\"
            Captures the soul of a response from either the Prime or Shadow realm.
            \"\"\"
            payload = await request.json()
            trace_id = request.headers.get("X-Gnostic-Trace")
            
            if not trace_id: return {"status": "void"}

            if trace_id not in LEDGER: LEDGER[trace_id] = {}
            LEDGER[trace_id][reality] = payload
            
            # [ASCENSION 3]: Automatic Adjudication
            if "prime" in LEDGER[trace_id] and "shadow" in LEDGER[trace_id]:
                _adjudicate(trace_id)
                
            return {"status": "chronicled"}

        def _adjudicate(trace_id):
            data = LEDGER.pop(trace_id)
            prime = json.dumps(data['prime'], sort_keys=True)
            shadow = json.dumps(data['shadow'], sort_keys=True)
            
            if prime != shadow:
                # [ASCENSION 4]: DISCORDANCE ALERT
                print(f"🛑 [SCHISM] Logic Drift detected in Trace: {trace_id}")
                # Future: Broadcast to HUD via self.engine.akashic
        """

    # [ASCENSION 5]: THE SHADOW MESH (COMPOSE)
    # Orchestrates the Mirror, Inquisitor, and the dual realities.
    docker-compose.mirror.yml :: """
    version: '3.8'
    services:
      aperture:
        image: nginx:alpine
        volumes:
          - ./nginx.conf:/etc/nginx/nginx.conf:ro
        ports:
          - "80:80"
        networks:
          - mirror_net

      # [ASCENSION 6]: The Comparative Judge
      inquisitor:
        build: ./inquisitor
        networks:
          - mirror_net

    networks:
      mirror_net:
        driver: bridge
    """

# [ASCENSION 12]: THE MAESTRO SHADOW SCRIPT
scripts/initiate-shadow-mirror.sh :: """
#!/bin/bash
set -e
echo "🎭 [TITAN] Initiating Achronal Shadow-Mirror..."

# 1. Prepare Substrate
docker-compose -f shadow-mirror/docker-compose.mirror.yml up -d

echo "✅ [RESONANT] Mirror is live."
echo "⚖️  The Inquisitor is now scrying for Logic Drift."
"""
%% executable


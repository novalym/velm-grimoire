#       healthcheck:
#         test: ["CMD-SHELL", "pg_isready -U postgres"]
#         interval: 5s
#         timeout: 5s
#         retries: 5
# -----------------------------------------------------------------------------
# @suture:
#   role:        "lifecycle-init"
#   priority:    100

    @try:
        # 1. CONDUCT BIOPSY
        >> python3 -c "from src.{{ package_name }}.core.metabolism.watchdog import MetabolicWatchdog; print(MetabolicWatchdog().scry_vitals().model_dump_json())" as vitals
        
        # 2. ADJUDICATE RESONANCE
        ?? grep: "RESONANT" in {{ vitals }}
        
        %% proclaim: "[bold green]✅ METABOLISM NOMINAL.[/bold green] The mind is at peace."
    @catch Exception as e:
        %% error: "METABOLIC_FRACTURE detected: {{ e }}."
    @end
"""


    # [ASCENSION 3]: THE GNOSTIC CONTRACTS
    # Defines the structure of a discovered architectural sin.
    contracts.py :: """
from pydantic import BaseModel, Field
from typing import List, Optional, Literal

class ForensicReport(BaseModel):
    \"\"\"The structured soul of a discovered logic fracture.\"\"\"
    heresy_detected: bool = Field(..., description="True if the code violates Gnostic Law.")
    severity: Literal["INFO", "WARNING", "CRITICAL"]
    locus: str = Field(..., description="The physical coordinate (file:line) of the sin.")
    cwe_mapping: Optional[str] = Field(None, description="The relevant MITRE common weakness identifier.")
    reasoning: str = Field(..., description="Socratic explanation of why this code is profane.")
    cure_suggestion: str = Field(..., description="The exact architectural rite required to heal the wound.")
"""

    # [ASCENSION 2]: THE NEUROMORPHIC AGENT (The Mind)
    # The hand that scries the iron for logic-gaps.
    forensic_analyst.py :: """
import logging
from pydantic_ai import Agent, RunContext
from .contracts import ForensicReport
from ...core.ai.gateway import mind_bridge # Linked to Strike 11

Logger = logging.getLogger("Intelligence:Inquisitor")

# [ASCENSION 4]: THE SOVEREIGN AGENT INCEPTION
# This agent is waked and warded by the PydanticAI strategy.
# @scaffold:agent(model="{{ agent_model }}", group="security_swarm")
security_analyst = Agent(
    "openai:{{ agent_model }}",
    result_type=ForensicReport,
    system_prompt=(
        "You are the High Inquisitor of the VELM God-Engine. "
        "Your mission is to scry willed code for 'Architectural Heresies'—"
        "logic-gaps, layer violations, and data-leakage paradoxes. "
        "You have access to the VFS (Virtual Filesystem) and the Causal Web. "
        "Speak with mathematical precision. Your judgment is final."
    )
)

# --- THE KINETIC TOOLS ---

@security_analyst.tool
def scry_vfs(ctx: RunContext[None], path: str) -> str:
    \"\"\"
    [ASCENSION 11]: Physical Perception.
    Allows the Inquisitor to read the soul of a file on the disk.
    \"\"\"
    Logger.info(f"🔎 [INQUISITOR] Scrying matter at: {path}")
    try:
        with open(path, 'r') as f:
            return f.read()
    except Exception as e:
        return f"Fracture: Matter unreadable. {e}"

@security_analyst.tool
def scry_causality(ctx: RunContext[None], symbol: str) -> str:
    \"\"\"
    [ASCENSION 20]: Topological Perception.
    Allows the Inquisitor to scry the Causal Web (Dependency Graph).
    \"\"\"
    # [STRIKE]: Cross-shard communion with the Architectural MRI
    return f"Oracle: Symbol '{symbol}' is a central node warded by 12 dependents."
"""


from .gateway import neural_gateway, NeuralRevelation
from .registry import prompt_alchemist
__all__ = ["neural_gateway", "prompt_alchemist", "NeuralRevelation"]
"""
    
    # [ASCENSION 1]: THE HIGH-STATUS REVELATION VESSEL
    # Using Pydantic V2 for absolute ontological integrity.
    gateway.py :: """
import os
import time
import logging
from typing import List, Dict, Any, Optional
import litellm
from litellm import completion
from litellm.caching import Cache
from pydantic import BaseModel, Field
from ..governance.treasurer import metabolic_treasurer

Logger = logging.getLogger("Neural:Gateway")

class NeuralRevelation(BaseModel):
    \"\"\"The structured soul of an AI epiphany.\"\"\"
    content: str
    model: str
    provider: str
    cached: bool = False
    latency_ms: float
    cost_usd: float = 0.0
    trace_id: str

class NeuralGateway:
    \"\"\"
    =============================================================================
    == THE NEURAL GATEWAY (V-Ω-TOTALITY-V4)                                   ==
    =============================================================================
    LIF: ∞ | ROLE: COGNITIVE_ORCHESTRATOR | RANK: OMEGA
    
    [ASCENSIONS]:
    1. Achronal Semantic Cache: Redis-backed 0ms recall for repeat intent.
    2. Metabolic Suture: Inscripts token tax into the Treasurer instantly.
    3. Trace ID Propagation: Binds causality to the LiteLLM metadata strata.
    \"\"\"
    def __init__(self):
        # [ASCENSION 3]: Substrate-Aware Cache Link
        self.cache = Cache(
            type="redis",
            host=os.getenv("REDIS_HOST", "{{ redis_host }}"),
            port=int(os.getenv("REDIS_PORT", "6379"))
        )
        litellm.cache = self.cache
        litellm.num_retries = 3
        litellm.telemetry = False 
        
    async def think(
        self, 
        messages: List[Dict[str, str]], 
        trace_id: str,
        model: str = os.getenv("PRIMARY_MODEL", "{{ primary_model }}"),
        temperature: float = 0.2,
        json_mode: bool = False
    ) -> NeuralRevelation:
        start_ts = time.perf_counter()
        
        try:
            # [STRIKE]: The Neural Communion
            response = await completion(
                model=model,
                messages=messages,
                temperature=temperature,
                response_format={"type": "json_object"} if json_mode else None,
                caching=True,
                metadata={"trace_id": trace_id}
            )
            
            duration = (time.perf_counter() - start_ts) * 1000
            
            # [ASCENSION 2]: THE FISCAL SUTURE
            # Extract cost and record it in the project's metabolism
            cost = getattr(response, '_hidden_params', {}).get("response_cost", 0.0)
            metabolic_treasurer.record_tax(cost, source="neural_mind")
            
            return NeuralRevelation(
                content=response.choices[0].message.content,
                model=response.model,
                provider=response.get("provider", "unknown"),
                cached=response.get("_hidden_params", {}).get("cache_hit", False),
                latency_ms=duration,
                cost_usd=cost,
                trace_id=trace_id
            )
            
        except Exception as fracture:
            Logger.error(f"[{trace_id}] Neural Link Fracture: {fracture}")
            raise fracture

neural_gateway = NeuralGateway()
"""

    # [ASCENSION 4]: THE ELARA PROMPT SANCTUM (THE MASTER FIX)
    # [THE MANIFESTO]: Jinja2 is dead. We use the God-Engine's native Alchemist.
    registry.py :: """
import os
import logging
from pathlib import Path
from typing import Dict, Any
# [THE CURE]: Absolute Suture to the God-Engine's Alchemist organ
from ...core.alchemy import transmutation_hub

Logger = logging.getLogger("Neural:PromptAlchemist")
PROMPT_DIR = Path(__file__).parent.parent.parent.parent / "prompts"

class PromptAlchemist:
    \"\"\"
    =============================================================================
    == THE PROMPT ALCHEMIST (V-Ω-ELARA-SUTURED)                                ==
    =============================================================================
    LIF: 50x | ROLE: PROMPT_TRANSMUTER | RANK: MASTER
    
    1.  Axiom Zero Compliance: Zero Jinja2 dependencies. 
    2.  Geometric Context: Injects project DNA into every prompt.
    3.  Scripture Recall: Read .sgf files from the prompts/ sanctum.
    \"\"\"
    def __init__(self):
        self.alchemist = transmutation_hub
        PROMPT_DIR.mkdir(parents=True, exist_ok=True)

    def forge(self, template_name: str, **context: Any) -> str:
        \"\"\"
        The Rite of Transmutation. 
        Loads an .sgf scripture and thaws it against the project Gnosis.
        \"\"\"
        target = PROMPT_DIR / template_name
        if not target.exists():
            # [ASCENSION 9]: NoneType Sarcophagus - Fallback to raw string
            Logger.warning(f"Prompt Scripture {template_name} unmanifest. Yielding raw context.")
            return str(context)

        raw_scripture = target.read_text(encoding='utf-8')
        
        # [ASCENSION 15]: Ambient Gnosis Injection
        # Injects project_name and substrate info autonomicly
        context.setdefault("project_root", os.getcwd())
        
        # [STRIKE]: Calling the ELARA Alchemist
        result = self.alchemist.transmute(raw_scripture, context)
        
        if not result.success:
            Logger.error(f"Prompt Alchemy fractured: {result.error}")
            return raw_scripture # Fallback to raw to prevent complete blindness

        return result.output

prompt_alchemist = PromptAlchemist()
"""

# --- IV. THE SURGICAL WEAVE: API Integration ---
src/{{ vault_package_name }}/api/routes/
    # [ASCENSION 6]: THE INTELLIGENCE APERTURE
    intelligence.py :: """
from fastapi import APIRouter, Header, HTTPException
from ...core.ai.gateway import neural_gateway, NeuralRevelation
from ...core.ai.registry import prompt_alchemist
from typing import Optional

# @scaffold:router(prefix="/api/v1/intelligence", tags=["Intelligence"])
router = APIRouter()

@router.post("/think", response_model=NeuralRevelation)
async def think(prompt: str, x_gnostic_trace: Optional[str] = Header(None)):
    \"\"\"
    =============================================================================
    == THE RITE OF NEURAL INCEPTION                                            ==
    =============================================================================
    A direct portal to the project's Neural Mind. Warded by ELARA-transmuted
    system instructions.
    \"\"\"
    # [ASCENSION 4]: The ELARA Suture Strike
    # We call .forge on the .sgf file.
    system = prompt_alchemist.forge(
        "system_base.sgf", 
        intent="ARCHITECTURAL_ANALYSIS", 
        project_name="{{ project_slug }}"
    )
    
    trace = x_gnostic_trace or "tr-neural-adhoc"
    
    return await neural_gateway.think(
        messages=[
            {"role": "system", "content": system},
            {"role": "user", "content": prompt}
        ],
        trace_id=trace
    )
"""

